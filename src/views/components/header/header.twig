{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}

<header class="store-header jebtha-header">
  <div id="mainnav" class="main-nav-container jebtha-main-nav flex items-center">
    <div class="inner w-full">
      <div class="container">
        <div class="jebtha-nav">

          <div class="jebtha-nav__left">
            <a class="lg:hidden mburger mburger--collapse leading-none jebtha-menu-trigger" href="#mobile-menu" aria-label="Open-menu">
              <i class="sicon-menu"></i>
            </a>

            <a class="navbar-brand jebtha-brand" href="{{ store.url }}">
              <img fetchpriority="high" width="100%" height="100%" loading="eager" src="{{ store.logo|cdn(175) }}" alt="{{ store.name }} logo">
              {% if is_page('index') %}
                <h1 class="sr-only">{{ store.name }}</h1>
              {% else %}
                <h2 class="sr-only">{{ store.name }}</h2>
              {% endif %}
            </a>

            <div class="jebtha-menu hidden lg:block">
              <custom-main-menu></custom-main-menu>
            </div>
          </div>

          <div class="jebtha-search hidden lg:block">
            <salla-search inline oval height="40"></salla-search>
          </div>

          <div class="jebtha-actions">
            <div class="jebtha-localization hidden lg:flex">
              {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                <salla-localization-modal show-trigger></salla-localization-modal>
              {% endif %}
            </div>

            {% if store.scope %}
              <button class="jebtha-scope hidden lg:flex" onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
                <i class="sicon-location"></i>
                <span>{{ store.scope.name }}</span>
              </button>
            {% endif %}

            <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>

            <salla-cart-summary class="jebtha-cart-summary">
              <i slot="icon" class="header-btn__icon icon sicon-shopping-bag"></i>
            </salla-cart-summary>
          </div>

        </div>
      </div>
    </div>
  </div>
</header>