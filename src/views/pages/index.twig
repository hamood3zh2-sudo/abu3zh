{#
| Variable         | Type       | Description                                                         |
|------------------|------------|---------------------------------------------------------------------|
| page             | object     |                                                                     |
| page.title       | string     | *could be html                                                      |
| page.slug        | string     | ex: "cat.show"                                                      |
#}
{% extends "layouts.master" %}

{% block content %}
  <section class="jebtha-home-hero">
    <div class="jebtha-home-hero__inner">
      <h1 class="jebtha-home-hero__title">
        كل منتجاتك المفضلة في مكان واحد
      </h1>

      <div class="jebtha-home-hero__categories" aria-label="تصنيفات المتجر">
        <a href="{{ store.url }}" class="jebtha-home-category">
          <span class="jebtha-home-category__icon">%</span>
          <span>تخفيضات</span>
        </a>

        <a href="{{ store.url }}" class="jebtha-home-category">
          <span class="jebtha-home-category__icon">👗</span>
          <span>الفساتين</span>
        </a>

        <a href="{{ store.url }}" class="jebtha-home-category">
          <span class="jebtha-home-category__icon">👚</span>
          <span>البلايز</span>
        </a>

        <a href="{{ store.url }}" class="jebtha-home-category">
          <span class="jebtha-home-category__icon">▣</span>
          <span>التنانير</span>
        </a>

        <a href="{{ store.url }}" class="jebtha-home-category">
          <span class="jebtha-home-category__icon">🧥</span>
          <span>الجاكيتات</span>
        </a>
      </div>
    </div>
  </section>

  <div class="jebtha-home-content">
    {% component home %}
  </div>
{% endblock %}

{% block scripts %}
  <script defer src="{{ 'home.js' | asset }}"></script>
{% endblock %}